# ─────────────────────────────────────────────────────────────────────────────
# CPM v3 — Environment configuration
# Copy to .env and edit. The startup orchestrator auto-generates RSA keys
# into ./keys/ on first boot — no manual key generation needed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Platform identity ─────────────────────────────────────────────────────────
SERVICE_VERSION=3.0.0
ENVIRONMENT=production            # production | staging | development

# ── Tenants ───────────────────────────────────────────────────────────────────
# Comma-separated tenant IDs. Topics and ACLs are created per tenant at startup.
TENANTS=t1

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka-broker:9092
KAFKA_ENABLE_ACLS=false           # true = per-tenant ACLs (requires SASL/SCRAM config)
KAFKA_NUM_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                   # leave blank for no auth (dev); set in production

# ── OPA ───────────────────────────────────────────────────────────────────────
OPA_URL=http://opa:8181
OPA_TIMEOUT=2.0

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Keys are AUTO-GENERATED by startup-orchestrator into ./keys/ on first boot.
# Paths below are container-internal (keys dir is mounted as a volume).
JWT_ALGORITHM=RS256
JWT_ISSUER=cpm-platform
JWT_AUDIENCE=cpm-api
JWT_PRIVATE_KEY_PATH=/keys/private.pem
JWT_PUBLIC_KEY_PATH=/keys/public.pem

# ── Guard model ───────────────────────────────────────────────────────────────
GUARD_MODEL_URL=http://guard-model:8200
GUARD_MODEL_ENABLED=true
GUARD_MODEL_TIMEOUT=2.0

# ── Groq (fast LLM inference for Llama Guard 3) ───────────────────────────────
# Get a free key at https://console.groq.com
# Leave blank to fall back to the built-in regex classifier
GROQ_API_KEY=
GROQ_MODEL=llama-guard-3-8b

# ── Anthropic (LLM backend) ───────────────────────────────────────────────────
# Set to enable real Claude responses through the secure gateway
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# Optional: SPM model registry ID to enforce lifecycle gating
LLM_MODEL_ID=

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=60                 # Max requests per minute per user
RATE_LIMIT_BURST=10               # Burst allowance above RPM

# ── CEP (Complex Event Processing) windows ────────────────────────────────────
CEP_SHORT_WINDOW_SEC=120          # Burst detection window (2 min)
CEP_LONG_WINDOW_SEC=3600          # Sustained volume window (1 hour)
CEP_SHORT_THRESHOLD=5             # Events in short window before burst alert
CEP_LONG_THRESHOLD=15             # Events in long window before sustained alert
CEP_INTENT_DRIFT_THRESHOLD=0.65   # Jaccard drift score above which to escalate
CEP_SESSION_HISTORY_SIZE=10       # Number of past prompts to keep for drift baseline

# ── Memory TTLs ───────────────────────────────────────────────────────────────
MEMORY_SESSION_TTL_SEC=3600       # Session memory: 1 hour
MEMORY_LONGTERM_TTL_SEC=2592000   # Long-term memory: 30 days
MEMORY_SYSTEM_TTL_SEC=86400       # System memory: 24 hours

# ── Output guard ──────────────────────────────────────────────────────────────
OUTPUT_GUARD_LLM_ENABLED=true     # Second-pass LLM semantic scan
OUTPUT_GUARD_LLM_URL=http://guard-model:8200
OUTPUT_GUARD_LLM_TIMEOUT=2.0

# ── Posture score thresholds ──────────────────────────────────────────────────
POSTURE_ALLOW_THRESHOLD=0.30      # Below this → allow
POSTURE_ESCALATE_THRESHOLD=0.70   # Between allow and block → escalate/review
POSTURE_BLOCK_THRESHOLD=0.70      # At or above this → block

# ── AI SPM Platform ─────────────────────────────────────────────────────────

# spm-db PostgreSQL credentials
SPM_DB_PASSWORD=spmpass
SPM_DB_RO_PASSWORD=spmpass_ro

# SPM API connection (used by startup-orchestrator and spm-aggregator)
SPM_API_URL=http://spm-api:8092

# SPM enforcement thresholds
SPM_MODEL_BLOCK_THRESHOLD=0.85   # rolling avg risk score to trigger enforcement
SPM_SNAPSHOT_INTERVAL_SEC=300    # posture snapshot bucket size (5 min)
SPM_ENFORCEMENT_WINDOW=3         # N snapshots to average before enforcing

# Compliance
SPM_COMPLIANCE_REFRESH_CRON="0 2 * * *"

# Model identity (stamped on PostureEnrichedEvent by Processor)
LLM_MODEL_ID=

# Grafana
GRAFANA_ADMIN_PASSWORD=admin

# Service-to-service JWT for SPM API (used when calling freeze-controller)
# Generate with: make spm-token-admin
# Leave empty to disable enforcement calls (dev/testing only)
SPM_SERVICE_JWT=
ANTHROPIC_API_KEY=