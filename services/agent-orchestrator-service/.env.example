# ─────────────────────────────────────────────────────────────────────────────
# agent-orchestrator-service  —  environment configuration
# Copy to .env and fill in values before running locally.
# ─────────────────────────────────────────────────────────────────────────────

# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_PORT=8094
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=agent_orchestrator.db           # Relative path for SQLite
# DB_URL=postgresql+asyncpg://user:pass@host:5432/dbname   # Swap for Postgres

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SESSION_CREATED=cpm.sessions.created
KAFKA_TOPIC_SESSION_BLOCKED=cpm.sessions.blocked
KAFKA_TOPIC_SESSION_RISK=cpm.sessions.risk_scored

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# In production, point to your JWKS endpoint (Keycloak / spm_api)
JWKS_URI=http://localhost:8092/jwks
JWT_AUDIENCE=agent-orchestrator
JWT_ISSUER=http://keycloak:8080/realms/cpm

# ── Policy Engine (OPA) ───────────────────────────────────────────────────────
OPA_URL=http://localhost:8181/v1/data/cpm/session/decision
# Leave blank to use built-in mock policy engine
POLICY_ENGINE_MODE=mock                 # mock | opa

# ── Risk Thresholds (override defaults) ───────────────────────────────────────
RISK_BLOCK_THRESHOLD=0.75
RISK_ESCALATE_THRESHOLD=0.50

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
