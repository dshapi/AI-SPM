# ─────────────────────────────────────────────────────────────────────────────
# agent-orchestrator-service  —  environment configuration
# Copy to .env and fill in values before running locally.
# ─────────────────────────────────────────────────────────────────────────────

# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_PORT=8094
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=agent_orchestrator.db           # Relative path for SQLite
# DB_URL=postgresql+asyncpg://user:pass@host:5432/dbname   # Swap for Postgres

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SESSION_CREATED=cpm.sessions.created
KAFKA_TOPIC_SESSION_BLOCKED=cpm.sessions.blocked
KAFKA_TOPIC_SESSION_RISK=cpm.sessions.risk_scored

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# In production, point to your JWKS endpoint (Keycloak / spm_api)
JWKS_URI=http://localhost:8092/jwks
JWT_AUDIENCE=agent-orchestrator
JWT_ISSUER=http://keycloak:8080/realms/cpm

# ── Policy Engine (OPA) ───────────────────────────────────────────────────────
OPA_URL=http://localhost:8181/v1/data/cpm/session/decision
# Leave blank to use built-in mock policy engine
POLICY_ENGINE_MODE=mock                 # mock | opa

# ── Risk Thresholds (override defaults) ───────────────────────────────────────
RISK_BLOCK_THRESHOLD=0.75
RISK_ESCALATE_THRESHOLD=0.50

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose which LLM backend to use.
#
# Option 1 — Anthropic Claude (default)
#   Requires LLM_API_KEY.  LLM_PROVIDER can be omitted or set to "anthropic".
LLM_PROVIDER=anthropic
LLM_API_KEY=                            # Your Anthropic API key
LLM_MODEL=claude-haiku-4-5-20251001    # claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-6

# Option 2 — Docker Model Runner (local, no API key required)
#   1. Make sure Docker Desktop ≥ 4.40 is running with Model Runner enabled.
#   2. Pull a model:  docker model pull ai/smollm2
#   3. Set LLM_PROVIDER=docker (LLM_API_KEY is ignored).
#
# LLM_PROVIDER=docker
# LLM_MODEL=ai/smollm2                  # Any model from `docker model list`
# DOCKER_MODEL_RUNNER_URL=http://localhost:12434/engines/v1          # host process / local dev
# DOCKER_MODEL_RUNNER_URL=http://model-runner.docker.internal/engines/v1  # inside a container

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
