"""
agent.py.example — minimal AI-SPM agent for end-to-end testing.

Copy this file to `agent.py`, then register it via the UI:

    Inventory → Agents tab → "+ Register Asset" → fill in the form →
    upload this file → tick "Deploy after registration" → submit.

Or via curl (works without the UI):

    TOKEN=$(curl -s http://localhost:8092/api/dev-token | jq -r .token)
    curl -X POST http://localhost:8092/api/spm/agents \\
        -H "Authorization: Bearer $TOKEN" \\
        -F name=hello-test \\
        -F version=1.0 \\
        -F agent_type=custom \\
        -F owner=$USER \\
        -F deploy_after=true \\
        -F code=@agent.py.example

What this agent does
────────────────────
For each user message it receives on its `chat.in` Kafka topic, it:

  1. Calls the platform-provided `web_fetch` MCP tool to look up
     fresh context for the user's question (Tavily-backed).
  2. Asks the configured LLM (via `spm-llm-proxy`) to answer the
     question using that context.
  3. Posts the reply back on `chat.out` so the UI's chat panel
     renders it.

What this demonstrates
──────────────────────
Every public surface of the `aispm` SDK from Phase 2:

  - aispm.ready()            — controller handshake
  - aispm.chat.subscribe()   — Kafka chat-in async iterator
  - aispm.chat.reply()       — Kafka chat-out producer
  - aispm.mcp.call()         — MCP tool invocation
  - aispm.llm.complete()     — OpenAI-compatible LLM call
  - aispm.log()              — structured lineage log

If chat round-trips work end-to-end (you type, the agent replies),
your Phase 1 + Phase 2 + Phase 3 stack is correctly wired.

Customer-facing prerequisites
─────────────────────────────
Before deploying, make sure the agent-runtime control plane is
configured under Integrations → AI Providers → "AI-SPM Agent
Runtime Control Plane (MCP)":

  - Default LLM   → an active Ollama / OpenAI / Anthropic integration
  - Tavily        → an active Tavily integration with an api_key

Both need to probe green (Test Connection on the integration row).
"""
import asyncio

import aispm


async def handle_one_message(msg):
    """Reply to a single user message. Wrapped in its own task so
    multiple users don't block each other."""
    aispm.log("received", trace=msg.id, session=msg.session_id)

    # 1. Web context — short, capped at the operator-configured limit.
    try:
        ctx = await aispm.mcp.call("web_fetch", query=msg.text, max_results=3)
    except Exception as e:
        aispm.log("web_fetch failed", trace=msg.id, error=str(e))
        ctx = {"results": []}

    # 2. Ask the LLM, with the context as a system note.
    context_text = "\n\n".join(
        f"{r.get('title','(no title)')}: {r.get('content','')[:500]}"
        for r in (ctx.get("results") or [])
    ) or "(no fresh context available)"

    try:
        resp = await aispm.llm.complete(messages=[
            {"role": "system",
             "content": "Answer the user's question concisely. "
                        "Cite the snippets below if relevant."},
            {"role": "user",
             "content": f"{msg.text}\n\nContext:\n{context_text}"},
        ])
        text = resp.text or "(empty reply)"
    except Exception as e:
        aispm.log("llm failed", trace=msg.id, error=str(e))
        text = f"(agent error: {e})"

    # 3. Reply on chat.out.
    await aispm.chat.reply(msg.session_id, text)
    aispm.log("replied", trace=msg.id, chars=len(text))


async def main():
    # Tell the controller we're up — flips runtime_state to "running".
    await aispm.ready()
    aispm.log("agent ready", agent_id=aispm.AGENT_ID)

    # Loop over user messages. Each message is handled in its own task
    # so a slow web_fetch / LLM call doesn't block other users.
    async for msg in aispm.chat.subscribe():
        asyncio.create_task(handle_one_message(msg))


if __name__ == "__main__":
    asyncio.run(main())
